-- fields to save (excludes Enabled so it
-- doesnt auto-enable on config load)
local SAVE_FIELDS = {
    "AimHead", "ShowFOV", "FOVRadius", "TeamCheck", "VisibleCheck",
    "Speed", "SpeedInAttack", "SpeedScaleFOV", "MaxLockOn", "ReactionTime",
    "Sensitivity", "ADSSensitivity",
}

local function saveConfig(name)
    if not name or name == "" then return false, "Empty name" end

    local data = {}
    for _, key in ipairs(SAVE_FIELDS) do
        data[key] = Settings[key]
    end

    local ok, err = pcall(function()
        local json = HttpService:JSONEncode(data)
        writefile(CONFIG_FOLDER .. "/" .. name .. ".json", json)
    end)

    return ok, err
end

local function loadConfig(name)
    if not name or name == "" then return false, "Empty name" end

    local path = CONFIG_FOLDER .. "/" .. name .. ".json"

    local ok, err = pcall(function()
        if not isfile(path) then
            error("Config not found")
        end

        local json = readfile(path)
        local data = HttpService:JSONDecode(json)

        for _, key in ipairs(SAVE_FIELDS) do
            if data[key] ~= nil then
                Settings[key] = data[key]
            end
        end
    end)

    return ok, err
end

local function deleteConfig(name)
    if not name or name == "" then return false end

    local ok = pcall(function()
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then
            delfile(path)
        end
    end)

    return ok
end

local function getConfigList()
    local list = {}
    pcall(function()
        local files = listfiles(CONFIG_FOLDER)
        for _, path in ipairs(files) do
            local name = path:match("([^/\\]+)%.json$")
            if name then
                table.insert(list, name)
            end
        end
    end)
    table.sort(list)
    return list
end

