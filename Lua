local phaseStatusLabel = nil -- set later when UI is built

--// =============================================
--// [9] MAIN RENDER LOOP
--//
--// every frame:
--//   1. update FOV circle
--//   2. find target
--//   3. handle target switching
--//   4. execute current phase logic
--// =============================================
local renderConnection

renderConnection = RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera

    -- update FOV circle
    if fovCircle then
        pcall(function()
            fovCircle.Position = getScreenCenter()
            fovCircle.Radius   = Settings.FOVRadius
            fovCircle.Visible  = Settings.ShowFOV
        end)
    end

    -- update status label
    if phaseStatusLabel then
        pcall(function()
            if not Settings.Enabled then
                phaseStatusLabel.Text = "Phase: OFF"
            else
                phaseStatusLabel.Text = "Phase: " .. Bezier.phase:upper()
            end
        end)
    end

    -- bail if disabled or no camera controller
    if not Settings.Enabled then
        Bezier.phase = "idle"
        Bezier.targetPlayer = nil
        Bezier.targetPart = nil
        return
    end
    if not CameraController then return end

    -- find target
    local targetPart, targetPlayer = getTarget()

    if not targetPart then
        -- lost target → reset to idle
        Bezier.phase = "idle"
        Bezier.targetPlayer = nil
        Bezier.targetPart = nil
        return
    end

    -- ————————————————————————————————
    -- TARGET SWITCH DETECTION
    -- if player changed, restart the curve
    -- ————————————————————————————————
    if targetPlayer ~= Bezier.targetPlayer then
        Bezier.targetPlayer = targetPlayer
        Bezier.targetPart   = targetPart

        pcall(function()
            setupBezierCurve(targetPart)
        end)
        return -- skip this frame, curve starts next frame
    end

    Bezier.targetPart = targetPart

    -- ————————————————————————————————
    -- PHASE: CURVING
    -- follow the bezier arc from start to target
    -- t progresses from 0 to 1 over ArrivalTime
    -- uses smoothstep easing for natural feel
    -- ————————————————————————————————
    if Bezier.phase == "curving" then
        pcall(function()
            local elapsed = tick() - Bezier.startTime
            local arrTime = math.max(Settings.ArrivalTime, 0.01)
            local rawT    = math.clamp(elapsed / arrTime, 0, 1)
            local t       = smoothstep(rawT)

            -- compute bezier delta at parameter t
            -- P0 = (0,0), P1 = (cpPitch, cpYaw), P2 = (endPitch, endYaw)
            local bPitch = bezierDelta(t, Bezier.cpPitch, Bezier.endPitch)
            local bYaw   = bezierDelta(t, Bezier.cpYaw,   Bezier.endYaw)

            -- apply: startRotation + bezierDelta
            local newPitch = Bezier.startRot.X + bPitch
            local newYaw   = Bezier.startRot.Y + bYaw

            CameraController:SetRotation(Vector2.new(newPitch, newYaw))

            -- when curve completes, move to settling
            if rawT >= 1 then
                Bezier.phase = "settling"
            end
        end)
        return
    end

    -- ————————————————————————————————
    -- PHASE: SETTLING
    -- correct overshoot back to actual target
    -- lerps from current overshot position
    -- toward real target position
    -- ————————————————————————————————
    if Bezier.phase == "settling" then
        pcall(function()
            local camPos  = Camera.CFrame.Position
            local dirUnit = (targetPart.Position - camPos).Unit

            local tgtPitch, tgtYaw = dirToAngles(dirUnit)
            local current = CameraController.Rotation

            -- settle alpha from SettleSpeed (1-20 → 0.05-1.0)
            local alpha = Settings.SettleSpeed / 20

            local newPitch = current.X + (tgtPitch - current.X) * alpha
            local newYaw   = current.Y + angleDiff(current.Y, tgtYaw) * alpha

            CameraController:SetRotation(Vector2.new(newPitch, newYaw))

            -- check if close enough to actual target
            -- threshold: ~0.5 degrees
            local pDiff = math.abs(tgtPitch - newPitch)
            local yDiff = math.abs(angleDiff(newYaw, tgtYaw))

            if pDiff < 0.008 and yDiff < 0.008 then
                Bezier.phase = "tracking"
            end
        end)
        return
    end

    -- ————————————————————————————————
    -- PHASE: TRACKING
    -- stay on target with natural wobble
    -- simulates human hand micro-movements
    -- multiple sine waves create organic feel
    -- ————————————————————————————————
    if Bezier.phase == "tracking" then
        pcall(function()
            local camPos  = Camera.CFrame.Position
            local dirUnit = (targetPart.Position - camPos).Unit

            local tgtPitch, tgtYaw = dirToAngles(dirUnit)

            -- add wobble for human-like aim
            local wPitch, wYaw = 0, 0
            if Settings.Wobble > 0 then
                wPitch, wYaw = getWobble(Bezier.wobbleSeed, Settings.Wobble)
            end

            local goalPitch = tgtPitch + wPitch
            local goalYaw   = tgtYaw   + wYaw

            -- smooth tracking (uses SettleSpeed)
            local current = CameraController.Rotation
            local alpha   = Settings.SettleSpeed / 20

            local newPitch = current.X + (goalPitch - current.X) * alpha
            local newYaw   = current.Y + angleDiff(current.Y, goalYaw) * alpha

            CameraController:SetRotation(Vector2.new(newPitch, newYaw))
        end)
        return
    end

    -- ————————————————————————————————
    -- PHASE: IDLE (shouldn't reach here with target)
    -- safety: if somehow idle with target, start curve
    -- ————————————————————————————————
    if Bezier.phase == "idle" and targetPart then
        pcall(function()
            setupBezierCurve(targetPart)
        end)
    end
end)

