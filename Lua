--// =============================================
--// [6] UTILITY FUNCTIONS
--// =============================================

local function getScreenCenter()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

-- wraps angle difference into [-pi, pi]
-- prevents 360 degree spin when crossing boundary
local function angleDiff(from, to)
    local d = to - from
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

-- check if player is currently shooting
-- on mobile, Rivals shoot button triggers MouseButton1
local function isAttacking()
    local ok, pressed = pcall(function()
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    end)
    return ok and pressed
end

-- find closest enemy part to screen center within FOV
local function getTarget()
    local center  = getScreenCenter()
    local bestPart = nil
    local bestDist = Settings.FOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local char = player.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local partName = Settings.AimHead and "Head" or "HumanoidRootPart"
        local part = char:FindFirstChild(partName)
        if not part then continue end

        local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestPart = part
        end
    end

    return bestPart
end

--// =============================================
--// [7] AIMBOT RENDER LOOP
--// every frame:
--//   1. update FOV circle
--//   2. find target in FOV
--//   3. handle lock-on state (max lock, reaction)
--//   4. calculate speed (base, attack, velocity)
--//   5. lerp CameraController rotation
--// =============================================
local renderConnection

renderConnection = RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera

    -- update FOV circle every frame
    if fovCircle then
        pcall(function()
            fovCircle.Position = getScreenCenter()
            fovCircle.Radius   = Settings.FOVRadius
            fovCircle.Visible  = Settings.ShowFOV
        end)
    end

    -- bail if disabled or no camera controller
    if not Settings.Enabled then
        LockState.targetPlayer = nil
        return
    end
    if not CameraController then return end

    -- COOLDOWN CHECK: after max lock expires, brief pause
    if tick() < LockState.cooldownUntil then return end

    -- find closest target in FOV
    local targetPart = getTarget()
    if not targetPart then
        LockState.targetPlayer = nil
        return
    end

    -- identify which player this target belongs to
    local targetPlayer = nil
    pcall(function()
        targetPlayer = Players:GetPlayerFromCharacter(targetPart.Parent)
    end)

    -- ————————————————————————————————
    -- TARGET SWITCH DETECTION
    -- if target player changed, reset lock timing
    -- this triggers reaction time for new targets
    -- ————————————————————————————————
    if targetPlayer ~= LockState.targetPlayer then
        LockState.targetPlayer  = targetPlayer
        LockState.lockStartTick = tick()
        LockState.switchTick    = tick()
    end

    -- ————————————————————————————————
    -- MAX LOCK ON CHECK
    -- drop target after N seconds of continuous lock
    -- adds cooldown before re-locking to prevent flicker
    -- 0 = unlimited (never drops)
    -- ————————————————————————————————
    if Settings.MaxLockOn > 0 then
        local lockElapsed = tick() - LockState.lockStartTick
        if lockElapsed > Settings.MaxLockOn then
            LockState.targetPlayer  = nil
            -- cooldown: at least reaction time, minimum 0.3s
            LockState.cooldownUntil = tick() + math.max(Settings.ReactionTime / 1000, 0.3)
            return
        end
    end

    -- ————————————————————————————————
    -- REACTION TIME CHECK
    -- don't aim until reaction delay has passed
    -- simulates human reaction to new target appearing
    -- 0 = instant (no delay)
    -- ————————————————————————————————
    if Settings.ReactionTime > 0 then
        local sinceSwitch = (tick() - LockState.switchTick) * 1000
        if sinceSwitch < Settings.ReactionTime then
            return
        end
    end

    -- ————————————————————————————————
    -- CALCULATE AIM ANGLES
    -- pitch = vertical (asin of Y)
    -- yaw   = horizontal (atan2 of -X, -Z)
    -- ————————————————————————————————
    pcall(function()
        local camPos    = Camera.CFrame.Position
        local targetPos = targetPart.Position
        local dirUnit   = (targetPos - camPos).Unit

        local targetPitch = math.asin(dirUnit.Y)
        local targetYaw   = math.atan2(-dirUnit.X, -dirUnit.Z)

        -- ————————————————————————————————
        -- CALCULATE SPEED (lerp alpha)
        --
        -- SPEED:          base tracking speed (0-5)
        -- SPEED IN ATTACK: faster speed while shooting (0-5)
        -- SPEED SCALE:     multiplier based on target velocity (0-100)
        --                  faster moving targets = more aggressive tracking
        --
        -- formula:
        --   baseAlpha = speed / 5  (normalizes 0-5 to 0-1)
        --   if attacking: use SpeedInAttack instead
        --   velFactor = 1 + (targetVelocity / 16) * (speedScale / 100)
        --   finalAlpha = clamp(baseAlpha * velFactor, 0, 1)
        -- ————————————————————————————————
        local currentSpeed = Settings.Speed
        if isAttacking() then
            currentSpeed = Settings.SpeedInAttack
        end

        local alpha = currentSpeed / 5

        -- SPEED SCALE: velocity-based multiplier
        if Settings.SpeedScale > 0 then
            local targetRoot = targetPart.Parent:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                local vel = targetRoot.AssemblyLinearVelocity.Magnitude
                -- 16 = default walkspeed, used as baseline
                -- at speedScale=100 and vel=16: doubles the alpha
                -- at speedScale=50 and vel=16: alpha * 1.5
                local velFactor = 1 + (vel / 16) * (Settings.SpeedScale / 100)
                alpha = alpha * velFactor
            end
        end

        alpha = math.clamp(alpha, 0, 1)

        -- ————————————————————————————————
        -- APPLY ROTATION
        -- lerp current toward target angles
        -- angleDiff handles ±pi wrapping on yaw
        -- ————————————————————————————————
        local current  = CameraController.Rotation
        local newPitch = current.X + (targetPitch - current.X) * alpha
        local newYaw   = current.Y + angleDiff(current.Y, targetYaw) * alpha

        CameraController:SetRotation(Vector2.new(newPitch, newYaw))
    end)
end)

