--// =============================================
--// [13] GLOBAL INPUT HANDLER
--// single handler for window drag + slider drag
--// prevents connection spam
--// =============================================
local windowDragging  = false
local windowDragStart = Vector2.zero
local windowStartPos  = UDim2.new()
local activeSlider    = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch
    or input.UserInputType == Enum.UserInputType.MouseButton1 then
        windowDragging  = true
        windowDragStart = Vector2.new(input.Position.X, input.Position.Y)
        windowStartPos  = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.Touch
    and input.UserInputType ~= Enum.UserInputType.MouseMovement then
        return
    end

    -- window drag
    if windowDragging then
        local delta = Vector2.new(input.Position.X, input.Position.Y) - windowDragStart
        mainFrame.Position = UDim2.new(
            windowStartPos.X.Scale,
            windowStartPos.X.Offset + delta.X,
            windowStartPos.Y.Scale,
            windowStartPos.Y.Offset + delta.Y
        )
    end

    -- slider drag
    if activeSlider then
        local s      = activeSlider
        local trackX = s.track.AbsolutePosition.X
        local trackW = s.track.AbsoluteSize.X
        local pct    = math.clamp((input.Position.X - trackX) / trackW, 0, 1)
        local rawVal = s.min + pct * (s.max - s.min)
        local val    = s.snap(rawVal)

        -- recalculate pct from snapped value for visual accuracy
        pct = math.clamp((val - s.min) / (s.max - s.min), 0, 1)

        s.fill.Size      = UDim2.new(pct, 0, 1, 0)
        s.thumb.Position = UDim2.new(pct, -9, 0.5, -9)
        s.label.Text     = s.name .. ": " .. string.format(s.fmt, val)
        s.value          = val

        if s.callback then s.callback(val) end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch
    or input.UserInputType == Enum.UserInputType.MouseButton1 then
        windowDragging = false
        activeSlider   = nil
    end
end)

