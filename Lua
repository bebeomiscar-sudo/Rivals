--// [6] CONFIG SYSTEM
--// =============================================
local SAVE_FIELDS = {
    "AimHead", "ShowFOV", "FOVRadius", "Smoothness",
    "TeamCheck", "VisibleCheck",
    "XSmooth", "YSmooth", "JumpSmoothing",
    "ClosestPart", "ClosestPosition",
}

local function saveConfig(name)
    if not name or name == "" then return false, "Empty name" end
    local data = {}
    for _, key in ipairs(SAVE_FIELDS) do data[key] = Settings[key] end
    local ok, err = pcall(function()
        writefile(CONFIG_FOLDER .. "/" .. name .. ".json", HttpService:JSONEncode(data))
    end)
    return ok, err
end

local function loadConfig(name)
    if not name or name == "" then return false, "Empty name" end
    local path = CONFIG_FOLDER .. "/" .. name .. ".json"
    local ok, err = pcall(function()
        if not isfile(path) then error("Config not found") end
        local data = HttpService:JSONDecode(readfile(path))
        for _, key in ipairs(SAVE_FIELDS) do
            if data[key] ~= nil then Settings[key] = data[key] end
        end
    end)
    return ok, err
end

local function deleteConfig(name)
    if not name or name == "" then return false end
    local ok = pcall(function()
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then delfile(path) end
    end)
    return ok
end

local function getConfigList()
    local list = {}
    pcall(function()
        for _, path in ipairs(listfiles(CONFIG_FOLDER)) do
            local name = path:match("([^/\\]+)%.json$")
            if name then table.insert(list, name) end
        end
    end)
    table.sort(list)
    return list
end

