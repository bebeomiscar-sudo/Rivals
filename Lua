--// =============================================
--// [8] UTILITY FUNCTIONS
--// =============================================

local function getScreenCenter()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

local function angleDiff(from, to)
    local d = to - from
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function isSameTeam(player)
    if not player or not LocalPlayer then return false end
    local ok1, r1 = pcall(function()
        if player.Team and LocalPlayer.Team then return player.Team == LocalPlayer.Team end
        return false
    end)
    if ok1 and r1 then return true end
    local ok2, r2 = pcall(function()
        if player.TeamColor and LocalPlayer.TeamColor then return player.TeamColor == LocalPlayer.TeamColor end
        return false
    end)
    if ok2 and r2 then return true end
    return false
end

local function isVisible(targetPart)
    if not targetPart then return false end
    local ok, result = pcall(function()
        local origin = Camera.CFrame.Position
        local direction = (targetPart.Position - origin)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        local filterList = {Camera}
        if LocalPlayer.Character then table.insert(filterList, LocalPlayer.Character) end
        params.FilterDescendantsInstances = filterList
        local hit = workspace:Raycast(origin, direction, params)
        if hit then return hit.Instance:IsDescendantOf(targetPart.Parent) end
        return true
    end)
    return ok and result or false
end

--// =============================================
--// [9] CLOSEST PART SYSTEM
--// when enabled, finds the body part whose
--// screen position is closest to crosshair
--// instead of always using Head or HumanoidRootPart
--// =============================================
local BODY_PARTS = {
    "Head", "HumanoidRootPart",
    "UpperTorso", "LowerTorso",
    "LeftUpperArm", "RightUpperArm",
    "LeftLowerArm", "RightLowerArm",
    "LeftUpperLeg", "RightUpperLeg",
    "LeftLowerLeg", "RightLowerLeg",
    -- R6 fallbacks
    "Torso", "Left Arm", "Right Arm",
    "Left Leg", "Right Leg",
}

local function getClosestPart(character)
    local center   = getScreenCenter()
    local bestPart = nil
    local bestDist = math.huge

    for _, partName in ipairs(BODY_PARTS) do
        local part = character:FindFirstChild(partName)
        if not part or not part:IsA("BasePart") then continue end

        local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestPart = part
        end
    end

    return bestPart
end

--// =============================================
--// [10] CLOSEST POSITION SYSTEM
--// when enabled, finds the closest POINT on the
--// part surface to the camera look ray
--// instead of aiming at part center (Position)
--//
--// uses the part's bounding box to clamp the
--// aim point to the nearest surface point
--// =============================================
local function getClosestPointOnPart(part)
    if not part then return nil end

    local ok, result = pcall(function()
        local camPos = Camera.CFrame.Position
        local camLook = Camera.CFrame.LookVector

        -- transform camera position into part local space
        local partCF   = part.CFrame
        local partSize = part.Size / 2

        local localCamPos = partCF:PointToObjectSpace(camPos)

        -- clamp the local camera position to the part bounds
        -- this gives us the nearest point on the surface
        local clampedX = math.clamp(localCamPos.X, -partSize.X, partSize.X)
        local clampedY = math.clamp(localCamPos.Y, -partSize.Y, partSize.Y)
        local clampedZ = math.clamp(localCamPos.Z, -partSize.Z, partSize.Z)

        local localClosest = Vector3.new(clampedX, clampedY, clampedZ)

        -- convert back to world space
        return partCF:PointToWorldSpace(localClosest)
    end)

    return ok and result or part.Position
end

--// =============================================
--// [11] CHECK IF TARGET IS AIRBORNE
--// used for JumpSmoothing — reduces tracking
--// speed when target is in the air
--// =============================================
local function isAirborne(character)
    if not character then return false end

    local ok, result = pcall(function()
        local hum = character:FindFirstChildOfClass("Humanoid")
        if not hum then return false end

        local state = hum:GetState()
        return state == Enum.HumanoidStateType.Freefall
            or state == Enum.HumanoidStateType.Jumping
            or state == Enum.HumanoidStateType.FallingDown
    end)

    return ok and result or false
end

--// =============================================
--// [12] FIND TARGET
--// =============================================
local function getTarget()
    local center   = getScreenCenter()
    local bestPart = nil
    local bestDist = Settings.FOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if Settings.TeamCheck and isSameTeam(player) then continue end

        local char = player.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        -- select which part to use
        local part

        if Settings.ClosestPart then
            -- find body part closest to crosshair
            part = getClosestPart(char)
        else
            -- default: Head or HumanoidRootPart
            local partName = Settings.AimHead and "Head" or "HumanoidRootPart"
            part = char:FindFirstChild(partName)
        end

        if not part then continue end
        if Settings.VisibleCheck and not isVisible(part) then continue end

        local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestPart = part
        end
    end

    return bestPart
end

--// =============================================
--// [13] MAIN RENDER LOOP
--//
--// SMOOTHNESS: base lerp alpha (1-100 / 100)
--//
--// DELAY POSITION:
--//   XSmooth: multiplier on yaw (horizontal) lerp
--//   YSmooth: multiplier on pitch (vertical) lerp
--//   JumpSmoothing: reduces speed on airborne targets
--//
--// CLOSEST PART: picks nearest body part to crosshair
--// CLOSEST POSITION: aims at nearest surface point
--// =============================================
local renderConnection

renderConnection = RunService.RenderStepped:Connect(function()
    Camera = workspace.CurrentCamera

    if fovCircle then
        pcall(function()
            fovCircle.Position = getScreenCenter()
            fovCircle.Radius   = Settings.FOVRadius
            fovCircle.Visible  = Settings.ShowFOV
        end)
    end

    if not Settings.Enabled then return end
    if not CameraController then return end

    local targetPart = getTarget()
    if not targetPart then return end

    pcall(function()
        local camPos = Camera.CFrame.Position

        -- get aim position
        -- either closest surface point or part center
        local aimPos
        if Settings.ClosestPosition then
            aimPos = getClosestPointOnPart(targetPart)
        else
            aimPos = targetPart.Position
        end

        local dirUnit = (aimPos - camPos).Unit

        -- target angles
        local targetPitch = math.asin(dirUnit.Y)
        local targetYaw   = math.atan2(-dirUnit.X, -dirUnit.Z)

        -- base smoothness alpha
        local baseAlpha = Settings.Smoothness / 100

        -- DELAY POSITION: separate X and Y multipliers
        -- XSmooth at 100% = full base speed horizontal
        -- XSmooth at 50% = half speed horizontal
        -- same for YSmooth on vertical axis
        local xFactor = Settings.XSmooth / 100
        local yFactor = Settings.YSmooth / 100

        local yawAlpha   = baseAlpha * xFactor
        local pitchAlpha = baseAlpha * yFactor

        -- JUMP SMOOTHING: reduce speed on airborne targets
        -- JumpSmoothing at 100% = full speed (no reduction)
        -- JumpSmoothing at 50% = half speed on jumping targets
        -- JumpSmoothing at 1% = almost no tracking on jumpers
        if isAirborne(targetPart.Parent) then
            local jumpFactor = Settings.JumpSmoothing / 100
            yawAlpha   = yawAlpha   * jumpFactor
            pitchAlpha = pitchAlpha * jumpFactor
        end

        -- clamp
        yawAlpha   = math.clamp(yawAlpha, 0, 1)
        pitchAlpha = math.clamp(pitchAlpha, 0, 1)

        -- get current rotation
        local current = CameraController.Rotation

        -- lerp each axis independently
        local newPitch = current.X + (targetPitch - current.X) * pitchAlpha
        local newYaw   = current.Y + angleDiff(current.Y, targetYaw) * yawAlpha

        CameraController:SetRotation(Vector2.new(newPitch, newYaw))
    end)
end)

