--// =============================================
--// [4] BEZIER STATE MACHINE
--//
--// Phases:
--//   IDLE     → no target
--//   CURVING  → following bezier arc to target
--//   SETTLING → correcting overshoot back to target
--//   TRACKING → on target with wobble
--//
--// Flow:
--//   [target found] → CURVING → SETTLING → TRACKING
--//   [target lost]  → IDLE
--//   [target changed] → restart CURVING
--// =============================================
local Bezier = {
    phase          = "idle",

    -- bezier curve data (set at acquisition)
    startRot       = Vector2.new(0, 0),  -- P0: rotation when target acquired
    cpPitch        = 0,                   -- control point pitch delta
    cpYaw          = 0,                   -- control point yaw delta
    endPitch       = 0,                   -- end point pitch delta (with overshoot)
    endYaw         = 0,                   -- end point yaw delta (with overshoot)
    curveDir       = 1,                   -- 1 or -1: which side the arc goes

    -- timing
    startTime      = 0,

    -- target tracking
    targetPlayer   = nil,
    targetPart     = nil,

    -- wobble randomization
    wobbleSeed     = 0,
}

