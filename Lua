local function refreshUIFromSettings()
    -- update sliders
    for key, slider in pairs(allSliders) do
        if Settings[key] ~= nil then
            slider:setValueFromCode(Settings[key])
        end
    end

    -- update toggles
    for key, toggle in pairs(allToggles) do
        if Settings[key] ~= nil then
            toggle.setState(Settings[key])
        end
    end
end

