--// =============================================
--// [18] UI COMPONENT — SLIDER (supports decimals)
--// `step` controls increment precision
--// touch-drag compatible for mobile
--// =============================================
local function createSlider(name, min, max, default, step, callback)
    step = step or 1

    -- figure out decimal places from step
    local decimals = 0
    local stepStr  = tostring(step)
    local dot      = stepStr:find("%.")
    if dot then decimals = #stepStr - dot end
    local fmt = "%." .. decimals .. "f"

    -- snap a raw value to the nearest step
    local function snap(raw)
        local v = math.floor(raw / step + 0.5) * step
        v = math.clamp(v, min, max)
        return tonumber(string.format(fmt, v))
    end

    local initPct = math.clamp((default - min) / (max - min), 0, 1)

    -- container
    local row = Instance.new("Frame")
    row.Name                   = "Slider_" .. name
    row.Size                   = UDim2.new(1, 0, 0, 52)
    row.BackgroundColor3       = C.surface
    row.BorderSizePixel        = 0
    row.LayoutOrder            = nextOrder()
    row.Parent                 = content

    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    -- label: "Name: Value"
    local lbl = Instance.new("TextLabel")
    lbl.Size                   = UDim2.new(1, -24, 0, 20)
    lbl.Position               = UDim2.new(0, 12, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = name .. ": " .. string.format(fmt, default)
    lbl.TextColor3             = C.textDim
    lbl.TextSize               = 12
    lbl.Font                   = Enum.Font.GothamMedium
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.Parent                 = row

    -- track
    local track = Instance.new("Frame")
    track.Name             = "Track"
    track.Size             = UDim2.new(1, -24, 0, 6)
    track.Position         = UDim2.new(0, 12, 0, 32)
    track.BackgroundColor3 = C.sliderTrack
    track.BorderSizePixel  = 0
    track.Parent           = row

    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    -- fill
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new(initPct, 0, 1, 0)
    fill.BackgroundColor3 = C.accent
    fill.BorderSizePixel  = 0
    fill.Parent           = track

    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    -- thumb
    local thumb = Instance.new("Frame")
    thumb.Size             = UDim2.new(0, 18, 0, 18)
    thumb.Position         = UDim2.new(initPct, -9, 0.5, -9)
    thumb.BackgroundColor3 = C.knob
    thumb.BorderSizePixel  = 0
    thumb.ZIndex           = 3
    thumb.Parent           = track

    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local thumbStroke = Instance.new("UIStroke")
    thumbStroke.Color     = C.accent
    thumbStroke.Thickness = 2
    thumbStroke.Parent    = thumb

    -- slider data (used by global InputChanged)
    local data = {
        track    = track,
        fill     = fill,
        thumb    = thumb,
        label    = lbl,
        name     = name,
        min      = min,
        max      = max,
        snap     = snap,
        fmt      = fmt,
        value    = default,
        callback = callback,
    }

    -- start drag on tap (enlarged invisible touch area)
    local touchArea = Instance.new("TextButton")
    touchArea.Size                   = UDim2.new(1, 12, 0, 34)
    touchArea.Position               = UDim2.new(0, -6, 0.5, -17)
    touchArea.BackgroundTransparency = 1
    touchArea.Text                   = ""
    touchArea.ZIndex                 = 4
    touchArea.Parent                 = track

    local function beginSlide(input)
        activeSlider = data
        -- update immediately to touch position
        local trackX = track.AbsolutePosition.X
        local trackW = track.AbsoluteSize.X
        local pct    = math.clamp((input.Position.X - trackX) / trackW, 0, 1)
        local val    = snap(min + pct * (max - min))

        pct = math.clamp((val - min) / (max - min), 0, 1)
        fill.Size      = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, -9, 0.5, -9)
        lbl.Text       = name .. ": " .. string.format(fmt, val)
        data.value     = val

        if callback then callback(val) end
    end

    touchArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch
        or input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginSlide(input)
        end
    end)

    return data
end

