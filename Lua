--// =============================================
--// [6] UTILITY FUNCTIONS
--// =============================================

local function getScreenCenter()
    return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

-- wrap angle difference into [-pi, pi]
-- prevents camera spinning 360 when crossing boundary
local function angleDiff(from, to)
    local d = to - from
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

-- smoothstep: accelerates then decelerates
-- makes the bezier movement feel natural
-- like a real hand starting and stopping
local function smoothstep(t)
    return t * t * (3 - 2 * t)
end

-- quadratic bezier: B(t) = (1-t)²P0 + 2(1-t)tP1 + t²P2
-- P0 is always 0 (start of delta space)
-- returns the delta value at parameter t
local function bezierDelta(t, cp, ep)
    local u = 1 - t
    return 2 * u * t * cp + t * t * ep
end

-- calculate pitch and yaw from a direction vector
-- pitch = vertical angle: math.asin(Y)
-- yaw   = horizontal angle: math.atan2(-X, -Z)
local function dirToAngles(dirUnit)
    return math.asin(dirUnit.Y), math.atan2(-dirUnit.X, -dirUnit.Z)
end

-- multi-frequency wobble for organic hand shake
-- uses 3 sine waves at different frequencies
-- so the pattern never looks repetitive
local function getWobble(seed, amount)
    local t = tick()
    local w = amount / 1000 -- scale: wobble 20 → 0.02 rad ≈ 1.1°

    local pitch = math.sin(t * 7.3 + seed) * w * 0.55
                + math.sin(t * 13.1 + seed * 1.7) * w * 0.30
                + math.sin(t * 23.7 + seed * 2.3) * w * 0.15

    local yaw   = math.cos(t * 5.7 + seed * 0.8) * w * 0.55
                + math.cos(t * 11.3 + seed * 1.4) * w * 0.30
                + math.cos(t * 19.9 + seed * 2.1) * w * 0.15

    return pitch, yaw
end

-- find closest enemy to screen center within FOV
local function getTarget()
    local center   = getScreenCenter()
    local bestPart = nil
    local bestPlr  = nil
    local bestDist = Settings.FOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local char = player.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local partName = Settings.AimHead and "Head" or "HumanoidRootPart"
        local part = char:FindFirstChild(partName)
        if not part then continue end

        local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestPart = part
            bestPlr  = player
        end
    end

    return bestPart, bestPlr
end

--// =============================================
--// [7] BEZIER CURVE SETUP
--// called when a new target is acquired
--// calculates the curved path from current
--// rotation to target rotation
--// =============================================
local function setupBezierCurve(targetPart)
    local camPos  = Camera.CFrame.Position
    local dirUnit = (targetPart.Position - camPos).Unit

    -- current rotation (start point)
    local startRot = CameraController.Rotation

    -- target angles
    local tgtPitch, tgtYaw = dirToAngles(dirUnit)

    -- angle deltas (yaw wrapped to shortest path)
    local dp = tgtPitch - startRot.X
    local dy = angleDiff(startRot.Y, tgtYaw)

    -- path length in angle space
    local pathLen = math.sqrt(dp * dp + dy * dy)

    -- randomize which side the curve arcs to
    -- alternates left/right for variety
    local curveDir = (math.random() > 0.5) and 1 or -1

    -- CONTROL POINT CALCULATION
    -- placed at midpoint of straight line
    -- then offset perpendicular by CurveIntensity
    --
    -- perpendicular direction in 2D:
    --   if path goes (dp, dy), perpendicular is (-dy, dp)
    --   normalized then scaled by intensity
    local cpPitch, cpYaw

    if pathLen > 0.001 then
        local perpPitch = -dy / pathLen
        local perpYaw   =  dp / pathLen

        local curveMag = (Settings.CurveIntensity / 100) * pathLen * 0.6 * curveDir

        cpPitch = dp * 0.5 + perpPitch * curveMag
        cpYaw   = dy * 0.5 + perpYaw   * curveMag
    else
        cpPitch = 0
        cpYaw   = 0
    end

    -- END POINT WITH OVERSHOOT
    -- extends past target by Overshoot percentage
    -- e.g. 10% overshoot: endpoint is 110% of the way
    local ovFactor = 1 + Settings.Overshoot / 100

    -- store everything in Bezier state
    Bezier.phase     = "curving"
    Bezier.startRot  = startRot
    Bezier.cpPitch   = cpPitch
    Bezier.cpYaw     = cpYaw
    Bezier.endPitch  = dp * ovFactor
    Bezier.endYaw    = dy * ovFactor
    Bezier.curveDir  = curveDir
    Bezier.startTime = tick()
    Bezier.wobbleSeed = math.random() * 100
end

