    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1, -70, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0); lbl.BackgroundTransparency = 1
    lbl.Text = name; lbl.TextColor3 = C.text; lbl.TextSize = 13
    lbl.Font = Enum.Font.GothamMedium; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row

    local pill = Instance.new("Frame"); pill.Size = UDim2.new(0, 44, 0, 24)
    pill.Position = UDim2.new(1, -56, 0.5, -12)
    pill.BackgroundColor3 = default and C.accent or C.toggleOff
    pill.BorderSizePixel = 0; pill.Parent = row
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local knobF = Instance.new("Frame"); knobF.Size = UDim2.new(0, 20, 0, 20)
    knobF.Position = default and UDim2.new(0, 22, 0, 2) or UDim2.new(0, 2, 0, 2)
    knobF.BackgroundColor3 = C.knob; knobF.BorderSizePixel = 0; knobF.Parent = pill
    Instance.new("UICorner", knobF).CornerRadius = UDim.new(1, 0)

    local ks = Instance.new("UIStroke"); ks.Color = Color3.new(0,0,0)
    ks.Thickness = 1; ks.Transparency = 0.85; ks.Parent = knobF

    local state = default
    local tweenI = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local function setVisual(v)
        knobF.Position = v and UDim2.new(0, 22, 0, 2) or UDim2.new(0, 2, 0, 2)
        pill.BackgroundColor3 = v and C.accent or C.toggleOff
    end

    local btn = Instance.new("TextButton"); btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1; btn.Text = ""; btn.ZIndex = 2; btn.Parent = row

    btn.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(knobF, tweenI, {
            Position = state and UDim2.new(0, 22, 0, 2) or UDim2.new(0, 2, 0, 2)
        }):Play()
        TweenService:Create(pill, tweenI, {
            BackgroundColor3 = state and C.accent or C.toggleOff
        }):Play()
        if callback then callback(state) end
    end)

    -- store reference for config reload
    if settingKey then
        allToggles[settingKey] = {
            setState = function(v)
                state = v
                setVisual(v)
            end,
            getState = function() return state end,
        }
    end
end

local function createSlider(name, settingKey, min, max, default, step, callback)
    step = step or 1
    local decimals = 0
    local ss = tostring(step); local dot = ss:find("%.")
    if dot then decimals = #ss - dot end
    local fmt = "%." .. decimals .. "f"

    local function snap(raw)
        local v = math.floor(raw / step + 0.5) * step
        v = math.clamp(v, min, max)
        return tonumber(string.format(fmt, v))
    end

    local initPct = math.clamp((default - min) / (max - min), 0, 1)

    local row = Instance.new("Frame"); row.Size = UDim2.new(1, 0, 0, 52)
    row.BackgroundColor3 = C.surface; row.BorderSizePixel = 0
    row.LayoutOrder = nextOrder(); row.Parent = content
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1, -24, 0, 20)
    lbl.Position = UDim2.new(0, 12, 0, 4); lbl.BackgroundTransparency = 1
    lbl.Text = name..": "..string.format(fmt, default); lbl.TextColor3 = C.textDim
    lbl.TextSize = 12; lbl.Font = Enum.Font.GothamMedium
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row

    local track = Instance.new("Frame"); track.Size = UDim2.new(1, -24, 0, 6)
    track.Position = UDim2.new(0, 12, 0, 32); track.BackgroundColor3 = C.sliderTrack
    track.BorderSizePixel = 0; track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame"); fill.Size = UDim2.new(initPct, 0, 1, 0)
    fill.BackgroundColor3 = C.accent; fill.BorderSizePixel = 0; fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local thumb = Instance.new("Frame"); thumb.Size = UDim2.new(0, 18, 0, 18)
    thumb.Position = UDim2.new(initPct, -9, 0.5, -9); thumb.BackgroundColor3 = C.knob
    thumb.BorderSizePixel = 0; thumb.ZIndex = 3; thumb.Parent = track
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local ts = Instance.new("UIStroke"); ts.Color = C.accent; ts.Thickness = 2; ts.Parent = thumb

    local data = {
        track = track, fill = fill, thumb = thumb, label = lbl,
        name = name, min = min, max = max, snap = snap, fmt = fmt,
        value = default, callback = callback, settingKey = settingKey,
    }

    -- method to update visual from code (config load)
    function data:setValueFromCode(val)
        val = snap(val)
        local pct = math.clamp((val - min) / (max - min), 0, 1)
        fill.Size      = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, -9, 0.5, -9)
        lbl.Text       = name .. ": " .. string.format(fmt, val)
        data.value     = val
        if callback then callback(val) end
    end

    local touchArea = Instance.new("TextButton"); touchArea.Size = UDim2.new(1, 12, 0, 34)
    touchArea.Position = UDim2.new(0, -6, 0.5, -17); touchArea.BackgroundTransparency = 1
    touchArea.Text = ""; touchArea.ZIndex = 4; touchArea.Parent = track

    local function beginSlide(input)
        activeSlider = data
        local tX = track.AbsolutePosition.X; local tW = track.AbsoluteSize.X
        local pct = math.clamp((input.Position.X - tX) / tW, 0, 1)
        local val = snap(min + pct * (max - min))
        pct = math.clamp((val - min) / (max - min), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0); thumb.Position = UDim2.new(pct, -9, 0.5, -9)
        lbl.Text = name..": "..string.format(fmt, val); data.value = val
        if callback then callback(val) end
    end

    touchArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch
        or input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginSlide(input)
        end
    end)

    if settingKey then
        allSliders[settingKey] = data
    end

    return data
end

